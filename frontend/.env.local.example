# ════════════════════════════════════════════════════════════════════════════════
# Frontend — environment variables
# Copy this file to .env.local and fill in your values.
# ════════════════════════════════════════════════════════════════════════════════

# ── Firebase (Client SDK) ────────────────────────────────────────────────────
# 1. Go to console.firebase.google.com → Create project
# 2. Project Settings → Add app → Web app
# 3. Copy the firebaseConfig object values below
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Firebase Admin SDK (Server) ──────────────────────────────────────────────
# Optional server-side auth helpers
# 1. Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → download JSON
# 3. Copy values from the downloaded JSON file
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Enable Google Sign-In ────────────────────────────────────────────────────
# Firebase Console → Authentication → Sign-in method → Google → Enable

# ── Email Delivery (optional) ───────────────────────────────────────────────
# Used for job-ready notifications.
# Uses Gmail SMTP with an App Password (NOT your regular Gmail password):
#   1. Enable 2FA on your Google account
#   2. myaccount.google.com → Security → App Passwords → "Mail"
NOTIFY_EMAIL_FROM=your.email@gmail.com
NOTIFY_EMAIL_PASS=your_gmail_app_password

# ── Backend API ──────────────────────────────────────────────────────────────
# Prefer 127.0.0.1 (not "localhost") so Node’s proxy matches uvicorn on IPv4.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
