# ════════════════════════════════════════════════════════════════════════════════
# ClixFair — environment variables
# Copy to .env and fill in all values before running docker compose.
# ════════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=clipfast
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=clipfast

# ── AI APIs ───────────────────────────────────────────────────────────────────
ASSEMBLY_AI_API_KEY=your_assemblyai_key_here
GOOGLE_API_KEY=your_google_gemini_key_here

# ── Google OAuth (YouTube Shorts publishing) ──────────────────────────────────
# console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Add redirect URIs: https://yourdomain.com/api/auth/youtube/callback
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# ── Stripe Checkout (clip credit packs) ──────────────────────────────────────
# Dashboard → Developers → API keys. Keep secret keys server-side only.
STRIPE_SECRET_KEY=sk_test_or_live_...
# Required in production so Stripe can grant credits server-to-server.
# Local dev: stripe listen --forward-to localhost:8000/api/billing/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Backend CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API in production.
# Example: https://clixfair.com,https://www.clixfair.com
# Leave blank to default to localhost-only (dev mode).
ALLOWED_ORIGINS=

# ── Firebase (Client SDK — baked into the frontend build) ────────────────────
# console.firebase.google.com → Project Settings → Web App → firebaseConfig
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Firebase Admin SDK (server-side auth helpers) ─────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate private key
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Email delivery ────────────────────────────────────────────────────────────
# Optional: used for job-ready notifications.
# Use a Gmail App Password (NOT your regular Gmail password):
#   1. Enable 2FA → myaccount.google.com → Security → App Passwords
NOTIFY_EMAIL_FROM=your.email@gmail.com
NOTIFY_EMAIL_PASS=your_gmail_app_password

# ── Optional tuning ───────────────────────────────────────────────────────────
# CHANNEL_POLL_INTERVAL_SEC=10800
# CHANNEL_POLL_INITIAL_DELAY_SEC=60
# CLIPFAST_DEBUG_ERRORS=1
# CLIPFAST_RENDER_CONCURRENCY=2
# CLIPFAST_FFMPEG_PRESET=faster
# CLIPFAST_FFMPEG_CRF=20
